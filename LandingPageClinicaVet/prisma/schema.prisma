generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Agendamento {
  id          String   @id @default(cuid())
  nome        String
  telefone    String
  email       String
  pet         String
  especie     String
  data        String
  horario     String
  observacoes String?
  createdAt   DateTime @default(now())
}

# Banco de dados (Prisma + PostgreSQL)
# DATABASE_URL: connection string "pooled" (usada pelo app em runtime).
# DIRECT_URL:   connection string "direta" (usada para migracoes / db push).
# Em Neon/Supabase ambas sao fornecidas no painel do banco.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Resend (envio de e-mail de confirmação) - OPCIONAL
# Sem esta chave o app funciona normalmente e apenas registra a confirmação no log.
RESEND_API_KEY=""
RESEND_FROM="Clinica VetVida <onboarding@resend.dev>"

# URL pública do site (usada em SEO / sitemap)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
